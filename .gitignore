# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── Secrets / Keys (never commit these) ──────────────────────────────────────
*.pem
*.key
*.p12
secrets/
credentials/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temp / generated files ────────────────────────────────────────────────────
msg.json
history/

# ── Local archive (removed from git, kept locally) ───────────────────────────
_archive/

# ── Confidential / internal docs (do not commit) ─────────────────────────────
*.docx
document/

# ── Working notes (personal tracking, never commit) ──────────────────────────
LEAD_TODO.md
LEAD_NOTES.md
*_TODO.md
*_NOTES.md

# ── Project context brief ────────────────────────────────────────────────────
PROJECT_BRIEF.md
*_BRIEF.md

# ── Claude settings (local, not for repo) ───────────────────────────────────
CLAUDE.md
.claude/

# ── Duplicate SDD tooling ────────────────────────────────────────────────────
here/

# ── Test suite report (generated, not for repo) ─────────────────────────────
TEST_SUITE_REPORT.md

# ── K8s secrets (real values never committed) ───────────────────────────────
infra/k8s/secret.yaml

# ── OpenWork workspace config (local, not for repo) ──────────────────────────
.opencode/openwork.json
opencode.jsonc

# ── Presentation binary (too large for git) ──────────────────────────────────
presentation/*.pptx

# ── SDD tooling (templates, not needed in production repo) ───────────────────
.specify/
