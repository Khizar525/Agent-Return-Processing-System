# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL_SECONDS=86400        # 24 hours (active sessions)
REDIS_ARCHIVE_TTL_SECONDS=7776000      # 90 days  (audit archive)

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_WEB_CHAT=agent01.webchat
KAFKA_TOPIC_EMAIL=agent01.email
KAFKA_TOPIC_WHATSAPP=agent01.whatsapp
KAFKA_TOPIC_SMS=agent01.sms

# ── Stripe (Payment) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# ── FedEx ─────────────────────────────────────────────────────────────────────
FEDEX_API_KEY=your-fedex-api-key
FEDEX_API_SECRET=your-fedex-api-secret
FEDEX_ACCOUNT_NUMBER=your-account-number

# ── UPS ───────────────────────────────────────────────────────────────────────
UPS_CLIENT_ID=your-ups-client-id
UPS_CLIENT_SECRET=your-ups-client-secret

# ── SendGrid (Email Notifications) ───────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-key-here
SENDGRID_FROM_EMAIL=support@yourstore.com
SENDGRID_FROM_NAME=Your Store Support

# ── Twilio (SMS Notifications) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACyour-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ── Zendesk / Freshdesk ───────────────────────────────────────────────────────
ZENDESK_SUBDOMAIN=yourcompany
ZENDESK_API_TOKEN=your-zendesk-api-token
ZENDESK_EMAIL=agent@yourcompany.com

# ── CRM ───────────────────────────────────────────────────────────────────────
CRM_BASE_URL=https://your-crm-api.com/v1
CRM_API_KEY=your-crm-api-key

# ── OMS (Order Management) ────────────────────────────────────────────────────
OMS_BASE_URL=https://your-oms-api.com/v1
OMS_API_KEY=your-oms-api-key

# ── Datadog ───────────────────────────────────────────────────────────────────
DD_API_KEY=your-datadog-api-key
DD_APP_KEY=your-datadog-app-key
DD_SERVICE=agent01-customer-support
DD_ENV=production

# ── Business Rules ────────────────────────────────────────────────────────────
RETURN_WINDOW_DAYS=30
REFUND_CAP_USD=500
SENTIMENT_ESCALATION_THRESHOLD=0.8
