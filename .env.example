# ── LLM Provider (OpenAI SDK-compatible) ─────────────────────────────────────
# Only opencode API key is used. Model: deepseek-v4-flash-free.
OPENAI_API_KEY=sk-your-opencode-api-key-here
OPENAI_BASE_URL=https://opencode.ai/zen/v1

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_WEB_CHAT=agent01.webchat
KAFKA_TOPIC_EMAIL=agent01.email
KAFKA_TOPIC_WHATSAPP=agent01.whatsapp
KAFKA_TOPIC_SMS=agent01.sms
WEBHOOK_URL=http://localhost:8000/webhook/message

# ── Datadog APM & Monitoring ──────────────────────────────────────────────────
# Leave blank to disable Datadog tracing (e.g. in local dev)
DD_API_KEY=
DD_APP_KEY=
DD_SERVICE=agent01-customer-support
DD_ENV=development
DD_VERSION=0.1.0
DD_SITE=datadoghq.com
DD_AGENT_HOST=localhost
DD_TRACE_AGENT_PORT=8126

# ── Business Rules ────────────────────────────────────────────────────────────
RETURN_WINDOW_DAYS=30
REFUND_CAP_USD=500
SENTIMENT_ESCALATION_THRESHOLD=0.8

# ── Communication (SendGrid / Twilio) ─────────────────────────────────────────
SENDGRID_FROM_NAME=Your Store Support
SENDGRID_FROM_EMAIL=support@agent01.example.com
